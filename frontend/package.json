{
  "name": "china-bedsheet-pos",
  "version": "1.0.0",
  "private": true,
  "description": "China Bedsheet POS desktop client",
  "author": "China Bedsheet Store",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "node --max-old-space-size=8192 ./node_modules/vite/bin/vite.js build",
    "preview": "vite preview",
    "build:unpacked": "npm run build && electron-builder --win dir",
    "build:desktop": "npm run build && electron-builder --win nsis",
    "build:portable": "npm run build && electron-builder --win portable",
    "build:installer": "npm run build:desktop"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.90.2",
    "axios": "^1.13.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.552.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.2",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.7.0",
    "electron": "^40.8.0",
    "electron-builder": "^26.8.1",
    "vite": "^5.4.21"
  },
  "build": {
    "appId": "com.chinabedsheet.pos",
    "icon": "src/assets/company logo.png",
    "productName": "China Bedsheet POS",
    "artifactName": "${productName}-Setup-${version}.${ext}",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../backend",
        "to": "backend",
        "filter": [
          "package.json",
          "package-lock.json",
          "src/**/*",
          "prisma/**/*",
          "node_modules/**/*"
        ]
      }
    ],
    "win": {
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false
    }
  }
}
